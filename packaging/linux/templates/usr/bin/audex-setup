#!/bin/bash
# ============================================================================
# Audex Setup Wizard
# ============================================================================

set -e

readonly AUDEX_VENV="/opt/audex/venv"
readonly SYSTEM_CONFIG_TEMPLATE="/etc/audex/templates/config.system.yml"
readonly USER_CONFIG="$HOME/.config/audex/config.yml"
readonly EXAMPLE_CONFIG="/etc/audex/templates/config.example.yml"
readonly TEMP_CONFIG="/tmp/audex-config-$$.yml"

readonly RED='\033[0;31m'
readonly YELLOW='\033[1;33m'
readonly GREEN='\033[0;32m'
readonly BLUE='\033[0;34m'
readonly NC='\033[0m'

# ============================================================================
# Cleanup
# ============================================================================

cleanup() {
    rm -f "$TEMP_CONFIG"
}
trap cleanup EXIT

# ============================================================================
# Check Virtual Environment
# ============================================================================

if [ ! -f "$AUDEX_VENV/bin/activate" ]; then
    echo -e "${RED}❌ Error: Virtual environment not found at $AUDEX_VENV${NC}"
    echo ""
    echo "Please reinstall Audex:"
    echo -e "  ${GREEN}sudo apt install --reinstall audex${NC}"
    exit 1
fi

# ============================================================================
# Check System Configuration Template
# ============================================================================

if [ ! -f "$SYSTEM_CONFIG_TEMPLATE" ]; then
    echo -e "${RED}❌ Error: System configuration template not found${NC}"
    echo "   Expected: $SYSTEM_CONFIG_TEMPLATE"
    echo ""
    echo "Please reinstall Audex:"
    echo -e "  ${GREEN}sudo apt install --reinstall audex${NC}"
    exit 1
fi

# ============================================================================
# Ensure User Directories
# ============================================================================

mkdir -p "$HOME/.config/audex"
mkdir -p "$HOME/.local/share/audex/store"
mkdir -p "$HOME/.local/share/audex/logs"

# ============================================================================
# Check Existing Configuration
# ============================================================================

CONFIG_SOURCE="$SYSTEM_CONFIG_TEMPLATE"

if [ -f "$USER_CONFIG" ]; then
    echo ""
    echo -e "${YELLOW}⚠️  Existing configuration found!${NC}"
    echo -e "${BLUE}📁 Location: ${NC}$USER_CONFIG"
    echo ""
    echo "What would you like to do?"
    echo ""
    echo -e "  ${GREEN}1) ${NC}Edit existing configuration"
    echo -e "  ${GREEN}2) ${NC}Create new configuration from template (overwrite)"
    echo -e "  ${GREEN}3) ${NC}Cancel setup"
    echo ""

    while true; do
        read -p "Enter your choice [1-3]: " choice
        case $choice in
            1)
                echo ""
                echo -e "${BLUE}📝 Loading existing configuration...${NC}"
                CONFIG_SOURCE="$USER_CONFIG"
                break
                ;;
            2)
                echo ""
                echo -e "${YELLOW}⚠️  This will overwrite your existing configuration!${NC}"
                read -p "Are you sure? [y/N]: " confirm
                if [[ $confirm =~ ^[Yy]$ ]]; then
                    BACKUP_FILE="$USER_CONFIG.backup.$(date +%Y%m%d_%H%M%S)"
                    cp "$USER_CONFIG" "$BACKUP_FILE"
                    echo -e "   ${GREEN}✓${NC} Backup saved: $BACKUP_FILE"
                    CONFIG_SOURCE="$SYSTEM_CONFIG_TEMPLATE"
                    break
                fi
                ;;
            3)
                echo ""
                echo -e "${BLUE}Setup cancelled.${NC}"
                exit 0
                ;;
            *)
                echo -e "${RED}Invalid choice. Please enter 1, 2, or 3.${NC}"
                ;;
        esac
    done
fi

# ============================================================================
# Expand Environment Variables
# ============================================================================

echo ""
echo -e "${BLUE}🔧 Audex Setup Wizard${NC}"
echo -e "${BLUE}Running as user: ${GREEN}$(whoami)${NC}"
echo ""
echo -e "${BLUE}📝 Preparing configuration...${NC}"

eval "cat <<EOF
$(cat "$CONFIG_SOURCE")
EOF
" > "$TEMP_CONFIG"

echo -e "   ${GREEN}✓${NC} Configuration prepared"
echo ""

# ============================================================================
# Audio Device Detection
# ============================================================================

echo -e "${BLUE}🎤 Detecting audio devices...${NC}"

"$AUDEX_VENV/bin/python" -c "
import pyaudio
import sys

try:
    pa = pyaudio.PyAudio()
    device_count = pa.get_device_count()

    input_devices = []
    for i in range(device_count):
        info = pa.get_device_info_by_index(i)
        if info['maxInputChannels'] > 0:
            input_devices.append((i, info['name'], info['maxInputChannels']))

    if input_devices:
        print('   ✓ Available input devices:')
        for idx, name, channels in input_devices:
            print(f'     [{idx}] {name} ({channels} channels)')
        print(f'   ✓ Total: {len(input_devices)} input device(s) found')
    else:
        print('   ⚠️  No input devices found')

    pa.terminate()

except Exception as e:
    print(f'   ❌ Audio detection failed: {e}')
    sys.exit(1)
" 2>/dev/null || {
    echo -e "   ${YELLOW}⚠️  Audio device detection failed${NC}"
    echo "   This may be resolved after completing the setup."
}

echo ""

# ============================================================================
# Run Setup Wizard
# ============================================================================

echo -e "${BLUE}🔧 Starting configuration wizard...${NC}"
echo ""

"$AUDEX_VENV/bin/python" -m audex init setup \
    --config "$TEMP_CONFIG" \
    --output "$USER_CONFIG"

# ============================================================================
# Check Result
# ============================================================================

if [ $? -eq 0 ] && [ -f "$USER_CONFIG" ]; then
    echo ""
    echo -e "${GREEN}✅ Configuration saved successfully! ${NC}"
    echo ""
    echo -e "${BLUE}📁 Configuration file:${NC}"
    echo "   $USER_CONFIG"
    echo ""
    echo -e "${BLUE}📋 Next steps:${NC}"
    echo ""
    echo "  1️⃣  Start Audex:"
    echo -e "     ${GREEN}audex${NC}"
    echo ""
    echo "  2️⃣  Enable auto-start (system-level):"
    echo -e "     ${GREEN}sudo systemctl enable audex@\$(whoami).service${NC}"
    echo -e "     ${GREEN}sudo systemctl start audex@\$(whoami).service${NC}"
    echo ""
    echo "  3️⃣  Check service status:"
    echo -e "     ${GREEN}systemctl status audex@\$(whoami).service${NC}"
    echo ""
    echo "  4️⃣  View logs:"
    echo -e "     ${GREEN}journalctl -u audex@\$(whoami).service -f${NC}"
    echo -e "     ${GREEN}tail -f ~/.local/share/audex/logs/audex.log${NC}"
    echo ""
    echo -e "${YELLOW}💡 Tips:${NC}"
    echo "   - Your config: $USER_CONFIG"
    echo "   - Example config: $EXAMPLE_CONFIG"
    echo "   - Re-run setup anytime: audex-setup"
    echo ""
else
    echo ""
    echo -e "${RED}❌ Setup failed or was cancelled${NC}"
    echo ""
    exit 1
fi

exit 0
